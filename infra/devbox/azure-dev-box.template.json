{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "allowedValues": [
                "australiaeast",
                "brazilsouth",
                "canadacentral",
                "centralus",
                "polandcentral",
                "spaincentral",
                "uaenorth",
                "westeurope",
                "germanywestcentral",
                "italynorth",
                "japaneast",
                "japanwest",
                "uksouth",
                "eastus",
                "eastus2",
                "southafricanorth",
                "southcentralus",
                "southeastasia",
                "switzerlandnorth",
                "swedencentral",
                "westus3",
                "centralindia",
                "eastasia",
                "northeurope",
                "koreacentral"
            ],
            "type": "String",
            "metadata": {
                "description": "Valid locations for all resources. This value can be same as the Region."
            }
        },
        "devCenterName": {
            "type": "String",
            "metadata": {
                "description": "The name of the Devcenter resource e.g. [devCenterName]-[autoGeneratedUniqueString]-dc. The autoGeneratedUniqueString will be 6 characters long."
            }
        },
        "projectName": {
            "type": "String",
            "metadata": {
                "description": "The name of the Project resource e.g. [projectName]"
            }
        },
        "poolName": {
            "type": "String",
            "metadata": {
                "description": "A Microsoft Hosted Network Pool in the region of the resouce group. The name of the Pool resource e.g. [poolName]-[region]-pool"
            }
        }
    },
    "variables": {
        "roleDefinitionId": "45d50f46-0b78-4001-a660-4198cbe8cd05",
        "principalId": "[deployer().objectId]",
        "devCenterUniqueName": "[concat(parameters('devCenterName'),'-', substring(uniqueString(resourceGroup().id), 0, 6), '-dc')]",
        "formattedPoolName": "[format('{0}-{1}', parameters('poolName'), parameters('location'))]",
        "poolPropertyAdmin": "Enabled",
        "poolPropertyNetworkType": "Managed",
        "poolPropertyNetworkName": "mhn-network",
        "image_win11_ent_vs2022": "microsoftvisualstudio_visualstudioplustools_vs-2022-ent-general-win11-m365-gen2",
        "compute_16c_64gb": "general_i_16c64gb512ssd_v2"
    },
    "resources": [
        {
            "type": "Microsoft.DevCenter/devcenters",
            "apiVersion": "2024-10-01-preview",
            "name": "[variables('devCenterUniqueName')]",
            "location": "[parameters('location')]",
            "tags": {
                "hidden-created-with": "devbox-quickstart-resource"
            },
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "projectCatalogSettings": {
                    "catalogItemSyncEnableStatus": "Enabled"
                },
                "networkSettings": {
                    "microsoftHostedNetworkEnableStatus": "Enabled"
                },
                "devBoxProvisioningSettings": {
                    "installAzureMonitorAgentEnableStatus": "Enabled"
                }
            }
        },
        {
            "type": "Microsoft.DevCenter/projects",
            "apiVersion": "2023-04-01",
            "name": "[parameters('projectName')]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.DevCenter/devcenters', variables('devCenterUniqueName'))]"
            ],
            "tags": {
                "hidden-created-with": "devbox-quickstart-resource"
            },
            "properties": {
                "devCenterId": "[resourceId('Microsoft.DevCenter/devcenters', variables('devCenterUniqueName') )]"
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(subscription().id, resourceGroup().id, variables('principalId'), variables('roleDefinitionId'))]",
            "dependsOn": [
                "[resourceId('Microsoft.DevCenter/projects', parameters('projectName'))]"
            ],
            "properties": {
                "description": "Allows deployer to create dev boxes in the project resource.",
                "principalId": "[variables('principalId')]",
                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', variables('roleDefinitionId'))]"
            },
            "scope": "[format('Microsoft.DevCenter/projects/{0}', parameters('projectName'))]"
        },
        {
            "type": "Microsoft.DevCenter/projects/pools",
            "apiVersion": "2024-10-01-preview",
            "name": "[format('{0}/{1}', parameters('projectName'), variables('formattedPoolName'))]",
            "location": "[parameters('location')]",
            "dependsOn": [
                "[resourceId('Microsoft.DevCenter/projects', parameters('projectName'))]"
            ],
            "tags": {
                "hidden-created-with": "devbox-quickstart-resource"
            },
            "properties": {
                "devBoxDefinitionType": "Value",
                "devBoxDefinitionName": "MarketplaceImage",
                "devBoxDefinition": {
                    "imageReference": {
                        "id": "[format('{0}/galleries/default/images/{1}', resourceId('Microsoft.DevCenter/devcenters', variables('devCenterUniqueName')), variables('image_win11_ent_vs2022'))]"
                    },
                    "sku": {
                        "name": "[variables('compute_16c_64gb')]"
                    }
                },
                "licenseType": "Windows_Client",
                "localAdministrator": "[variables('poolPropertyAdmin')]",
                "managedVirtualNetworkRegions": [
                    "[parameters('location')]"
                ],
                "virtualNetworkType": "[variables('poolPropertyNetworkType')]",
                "networkConnectionName": "[format('{0}-{1}', variables('poolPropertyNetworkName'), parameters('location'))]"
            }
        }
    ]
}
